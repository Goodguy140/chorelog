{
  "openapi": "3.0.3",
  "info": {
    "title": "Chorelog API",
    "version": "1.0.0",
    "description": "HTTP API for Chorelog (household chore tracker).\n\nMost routes require a session cookie **`chorelog_auth`** set by **`POST /api/login`** (HttpOnly, SameSite=Lax). Send cookies on subsequent requests.\n\nIntegrations can alternatively send `Authorization: Bearer <api-token>` after creating a token in Account settings.\n\nJSON bodies use `Content-Type: application/json`."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3000",
      "description": "This instance"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Login, logout, session, registration hints"
    },
    {
      "name": "Account",
      "description": "Signed-in user / household session info"
    },
    {
      "name": "Households",
      "description": "Create tenant (when enabled by server env)"
    },
    {
      "name": "Data",
      "description": "Main store: entries, people, locations, presets, scheduled chores"
    },
    {
      "name": "Entries",
      "description": "Activity log rows"
    },
    {
      "name": "Scheduled",
      "description": "Recurring chores"
    },
    {
      "name": "Settings",
      "description": "Household settings batch update"
    },
    {
      "name": "Webhooks",
      "description": "Discord / Slack / generic overdue notifications"
    },
    {
      "name": "Push",
      "description": "Web Push (VAPID) for PWA browser notifications"
    },
    {
      "name": "Admin",
      "description": "Admin household (slug `default`) only — VAPID persistence and debugging"
    },
    {
      "name": "Export",
      "description": "Backup and CSV export"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "chorelog_auth",
        "description": "Set by POST /api/login; include in Cookie header for protected routes."
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API token",
        "description": "Create in Account settings; use `Authorization: Bearer <token>`."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "AuthOk": {
        "type": "object",
        "properties": {
          "authenticated": {
            "type": "boolean"
          },
          "user": {
            "type": "string"
          },
          "household": {
            "type": "string"
          },
          "readOnly": {
            "type": "boolean",
            "description": "True when the session is guest / view-only (JWT ro)."
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "password"
        ],
        "properties": {
          "household": {
            "type": "string",
            "description": "Household id slug; default applied if omitted"
          },
          "username": {
            "type": "string",
            "description": "Display name for audit log"
          },
          "password": {
            "type": "string"
          },
          "guest": {
            "type": "boolean",
            "description": "When true, password must match CHORELOG_GUEST_PASSWORD; session is read-only."
          }
        }
      },
      "LoginMembersRequest": {
        "type": "object",
        "required": [
          "password"
        ],
        "properties": {
          "household": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "guest": {
            "type": "boolean",
            "description": "When true, password must match CHORELOG_GUEST_PASSWORD instead of the household password."
          }
        }
      },
      "LoginMembersResponse": {
        "type": "object",
        "properties": {
          "people": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "RegisterInfo": {
        "type": "object",
        "properties": {
          "openRegistration": {
            "type": "boolean"
          },
          "hasMasterPassword": {
            "type": "boolean"
          },
          "allowCreateHousehold": {
            "type": "boolean"
          },
          "guestLoginEnabled": {
            "type": "boolean",
            "description": "True when CHORELOG_GUEST_PASSWORD is set (guest / view-only sign-in available)."
          }
        }
      },
      "CreateHouseholdRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "householdId": {
            "type": "string",
            "description": "Alias for id"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "masterPassword": {
            "type": "string"
          }
        }
      },
      "AccountInfo": {
        "type": "object",
        "properties": {
          "user": {
            "type": "string"
          },
          "household": {
            "type": "string"
          },
          "readOnly": {
            "type": "boolean",
            "description": "Guest / view-only session."
          },
          "sessionExpiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "canCreateHouseholds": {
            "type": "boolean"
          },
          "openRegistration": {
            "type": "boolean"
          },
          "browserPushAllowed": {
            "type": "boolean",
            "description": "True when the session household may manage browser (Web Push) subscriptions (default / admin household only)."
          }
        }
      },
      "ReadOnlyError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "code": {
            "const": "read_only",
            "description": "Mutating request rejected for guest / read-only session."
          }
        }
      }
    }
  },
  "security": [
    {
      "cookieAuth": []
    },
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/auth": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Session status",
        "security": [],
        "responses": {
          "200": {
            "description": "Authenticated or anonymous",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "authenticated": {
                          "const": false
                        }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "authenticated": {
                          "const": true
                        },
                        "user": {
                          "type": "string"
                        },
                        "household": {
                          "type": "string"
                        },
                        "readOnly": {
                          "type": "boolean"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/version": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "App and runtime version",
        "security": [],
        "responses": {
          "200": {
            "description": "Version payload; extra fields when authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/api/openapi.json": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "This OpenAPI document (JSON)",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI 3.0 document"
          }
        }
      }
    },
    "/api/register-info": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Registration options for this server",
        "security": [],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Sign in (sets session cookie)",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "const": true
                    },
                    "household": {
                      "type": "string"
                    },
                    "readOnly": {
                      "type": "boolean",
                      "description": "True for guest login sessions."
                    }
                  }
                }
              }
            },
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Brute-force throttle",
            "headers": {
              "Retry-After": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "retryAfterSeconds": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/login/members": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "List household people after password check (no session)",
        "description": "Same throttle as login on failures. Used for login UI step 1 → 2.",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginMembersRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginMembersResponse"
                }
              }
            }
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "429": {
            "description": "Too many attempts"
          }
        }
      }
    },
    "/api/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Sign out (clears cookie)",
        "security": [],
        "responses": {
          "204": {
            "description": "No content"
          }
        }
      }
    },
    "/api/households": {
      "post": {
        "tags": [
          "Households"
        ],
        "summary": "Create a new household",
        "description": "Requires `CHORELOG_OPEN_REGISTRATION=1` and/or valid `CHORELOG_MASTER_PASSWORD`.",
        "security": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHouseholdRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "const": true
                    },
                    "household": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Household id already exists"
          }
        }
      }
    },
    "/api/account": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "Current account / session summary",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountInfo"
                }
              }
            }
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/display-name": {
      "put": {
        "tags": [
          "Account"
        ],
        "summary": "Update display name (re-issues cookie)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user"
                ],
                "properties": {
                  "user": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "const": true
                    },
                    "user": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadOnlyError"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/password": {
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "Change this household password",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "currentPassword": {
                    "type": "string"
                  },
                  "newPassword": {
                    "type": "string",
                    "minLength": 8
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "New password too short"
          },
          "401": {
            "description": "Current password wrong"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadOnlyError"
                }
              }
            }
          }
        }
      }
    },
    "/api/account/api-tokens": {
      "get": {
        "tags": [
          "Account"
        ],
        "summary": "List active API tokens for the current household",
        "security": [
          {
            "cookieAuth": []
          },
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Account"
        ],
        "summary": "Create a new API token (token value returned once)",
        "security": [
          {
            "cookieAuth": []
          },
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "label"
                ],
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "scope": {
                    "type": "string",
                    "enum": [
                      "rw",
                      "ro"
                    ]
                  },
                  "ownerType": {
                    "type": "string",
                    "enum": [
                      "household",
                      "personal"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/account/api-tokens/{id}": {
      "delete": {
        "tags": [
          "Account"
        ],
        "summary": "Revoke an API token",
        "security": [
          {
            "cookieAuth": []
          },
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Revoked"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/audit": {
      "get": {
        "tags": [
          "Data"
        ],
        "summary": "Audit log",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 500
            },
            "description": "Max rows (capped at 500)"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "auditLog": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/entries": {
      "get": {
        "tags": [
          "Data"
        ],
        "summary": "Load full household store slice (entries, people, locations, …)",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Entries"
        ],
        "summary": "Create log entries (batch)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "entries"
                ],
                "properties": {
                  "entries": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "d": {
                          "type": "string",
                          "description": "Date YYYY-MM-DD"
                        },
                        "p": {
                          "type": "string",
                          "description": "Person name"
                        },
                        "c": {
                          "type": "string",
                          "description": "Chore text if no choreId"
                        },
                        "choreId": {
                          "type": "string"
                        },
                        "locationIds": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "note": {
                          "type": "string",
                          "description": "Optional short comment (max 280)"
                        },
                        "attachmentBase64": {
                          "type": "string",
                          "description": "Optional image: base64 or data URL (only when posting a single entry). JPEG, PNG, WebP, GIF; max size enforced server-side."
                        },
                        "attachmentMime": {
                          "type": "string",
                          "description": "MIME type when sending raw base64 (e.g. image/jpeg). Optional for data URLs."
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/entries/{id}": {
      "put": {
        "tags": [
          "Entries"
        ],
        "summary": "Update a log entry",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "d": {
                    "type": "string"
                  },
                  "p": {
                    "type": "string"
                  },
                  "c": {
                    "type": "string"
                  },
                  "choreId": {
                    "type": "string"
                  },
                  "locationIds": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "note": {
                    "type": "string"
                  },
                  "expectedUpdatedAt": {
                    "type": "string"
                  },
                  "attachmentBase64": {
                    "type": "string",
                    "description": "Replace image: base64 or data URL"
                  },
                  "attachmentMime": {
                    "type": "string"
                  },
                  "removeAttachment": {
                    "type": "boolean",
                    "description": "Remove stored image from this entry"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated entry"
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Entries"
        ],
        "summary": "Soft-remove a log entry (hidden from stats; restorable)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Removed"
          },
          "400": {
            "description": "Already removed"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/entries/{id}/restore": {
      "post": {
        "tags": [
          "Entries"
        ],
        "summary": "Restore a soft-removed log entry",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Restored entry",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          },
          "400": {
            "description": "Not removed"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/entries/{id}/attachment": {
      "get": {
        "tags": [
          "Entries"
        ],
        "summary": "Download optional photo attached to a log entry",
        "security": [
          {
            "cookieAuth": []
          },
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Image bytes",
            "content": {
              "image/jpeg": {},
              "image/png": {},
              "image/webp": {},
              "image/gif": {}
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/api/scheduled-chores": {
      "post": {
        "tags": [
          "Scheduled"
        ],
        "summary": "Create scheduled chore",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "intervalDays": {
                    "type": "number"
                  },
                  "recurrence": {
                    "type": "string",
                    "enum": [
                      "interval",
                      "monthlyWeekday"
                    ],
                    "description": "interval = rolling N-day cadence; monthlyWeekday = nth weekday of month"
                  },
                  "monthOrdinal": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5,
                    "description": "1–4 = first–fourth occurrence; 5 = last such weekday in the month"
                  },
                  "weekday": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 6,
                    "description": "0 = Sunday … 6 = Saturday (JavaScript Date)"
                  },
                  "startsOn": {
                    "type": "string"
                  },
                  "createdAt": {
                    "type": "string"
                  },
                  "reminderEnabled": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Missing title"
          }
        }
      }
    },
