# Copy to `.env` next to docker-compose.yml (never commit `.env`).
# Used by docker-compose variable substitution.

CHORELOG_SECRET=change-me-to-a-long-random-string
CHORELOG_USER=house
CHORELOG_PASSWORD=change-me

# docker-compose.autopull.yml — public Git clone URL (HTTPS) and poll interval (seconds)
# GIT_REPO=https://github.com/YOUR_ORG/chorelog.git
# GIT_BRANCH=main
# SYNC_INTERVAL=300
